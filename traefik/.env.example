# Traefik Stack Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored and should only live on the host

# Domain Traefik uses to serve the dashboard
# Example: traefik.yourdomain.com
TRAEFIK_DOMAIN=traefik.localhost

# Timezone for the container
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Ports Traefik listens on (change if 80/443 are already in use on the host)
# NOTE: HTTP_PORT must forward to external port 80 for Let's Encrypt httpChallenge to work
HTTP_PORT=80
HTTPS_PORT=443

# Email Let's Encrypt uses for cert expiry notifications
ACME_EMAIL=you@yourdomain.com
