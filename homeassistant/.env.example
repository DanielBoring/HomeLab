# Home Assistant
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.

# ─── Timezone ──────────────────────────────────────────────────────────────────

TZ=America/New_York

# ─── Traefik ───────────────────────────────────────────────────────────────────

# Hostname Traefik will route to Home Assistant
HOMEASSISTANT_DOMAIN=home.virtuallyboring.com

# ─── Ports (optional) ──────────────────────────────────────────────────────────

# Host port for direct LAN access (companion app, wall tablets, local dashboards)
# Traefik uses container port 8123 directly — this only affects host binding
# HOMEASSISTANT_PORT=8123
