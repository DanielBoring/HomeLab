# Karakeep version — pin to a specific release (e.g. 0.10.0) or use "release" for latest stable
KARAKEEP_VERSION=release

# Domain served by Traefik
KARAKEEP_DOMAIN=karakeep.virtuallyboring.com

# Auth secret — generate with: openssl rand -base64 36
NEXTAUTH_SECRET=change_me

# Meilisearch master key — generate with: openssl rand -base64 36
MEILISEARCH_MASTER_KEY=change_me

# Optional: OpenAI API key for automatic bookmark tagging
# OPENAI_API_KEY=sk-...
