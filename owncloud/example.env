# OwnCloud Infinite Scale (OCIS)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.

# ─── Domain ───────────────────────────────────────────────────────────────────

OCIS_DOMAIN=cloud.yourdomain.com

# ─── Admin Account (first run only) ───────────────────────────────────────────
# Used by `ocis init` to set the initial admin password.
# After first startup this var is ignored — change the password via the web UI.

OCIS_ADMIN_PASSWORD=your_admin_password_here

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Used by `ocis init` on first run. If left blank, ocis init auto-generates them
# and writes the values into /etc/ocis/ocis.yaml (the config volume).
# Pre-setting them here is recommended so you can restore config from scratch.
# Generate each with: openssl rand -hex 32

OCIS_JWT_SECRET=
OCIS_TRANSFER_SECRET=
OCIS_MACHINE_AUTH_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

TZ=America/New_York
# OCIS_LOG_LEVEL=warn
