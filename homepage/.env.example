# Homepage
# The hostname Traefik will route to homepage
HOMEPAGE_DOMAIN=homepage.yourdomain.com

# Hosts allowed to access homepage — behind Traefik this is just the hostname, no port
HOMEPAGE_ALLOWED_HOSTS=homepage.yourdomain.com

# Pi-hole
HOMEPAGE_VAR_PIHOLE1_URL=http://10.0.0.x
HOMEPAGE_VAR_PIHOLE1_API_KEY=your_pihole1_api_key
HOMEPAGE_VAR_PIHOLE2_URL=http://10.0.0.x
HOMEPAGE_VAR_PIHOLE2_API_KEY=your_pihole2_api_key

# Portainer
HOMEPAGE_VAR_PORTAINER_URL=https://10.0.0.x:31015
HOMEPAGE_VAR_PORTAINER_API_KEY=your_portainer_api_key

# Home Assistant
HOMEPAGE_VAR_HOME_ASSISTANT_URL=http://10.0.0.x:8123
HOMEPAGE_VAR_HOME_ASSISTANT_API_KEY=your_home_assistant_long_lived_token

# UniFi
HOMEPAGE_VAR_UNIFI_URL=https://10.0.0.x
HOMEPAGE_VAR_UNIFI_USERNAME=your_readonly_user
HOMEPAGE_VAR_UNIFI_PASSWORD=your_password

# Monitoring & observability
HOMEPAGE_VAR_UPTIME_KUMA_URL=http://uptime-kuma:3001
HOMEPAGE_VAR_UPTIME_KUMA_SLUG=your_status_page_slug
HOMEPAGE_VAR_GRAFANA_URL=http://10.0.0.x:3000
HOMEPAGE_VAR_GRAFANA_USERNAME=admin
HOMEPAGE_VAR_GRAFANA_PASSWORD=your_grafana_password
HOMEPAGE_VAR_PROMETHEUS_URL=http://10.0.0.x:9090
HOMEPAGE_VAR_DOZZLE_URL=http://10.0.0.x:8087

# Documents, media & library
HOMEPAGE_VAR_NEXTCLOUD_URL=http://10.0.0.x:8020
HOMEPAGE_VAR_NEXTCLOUD_USERNAME=your_username
HOMEPAGE_VAR_NEXTCLOUD_PASSWORD=your_password
HOMEPAGE_VAR_PAPERLESS_URL=http://10.0.0.x:8010
HOMEPAGE_VAR_PAPERLESS_API_KEY=your_paperless_api_token
HOMEPAGE_VAR_CALIBRE_WEB_URL=http://10.0.0.x:8083
HOMEPAGE_VAR_CALIBRE_WEB_USERNAME=your_username
HOMEPAGE_VAR_CALIBRE_WEB_PASSWORD=your_password

# Automation & utilities
HOMEPAGE_VAR_CHANGEDETECTION_URL=http://10.0.0.x:5000
HOMEPAGE_VAR_CHANGEDETECTION_API_KEY=your_changedetection_api_key
HOMEPAGE_VAR_SEMAPHORE_URL=http://10.0.0.x:3003
HOMEPAGE_VAR_SEMAPHORE_API_KEY=your_semaphore_api_token
