# Dozzle
# Copy this file to .env and adjust values for your environment.

# Timezone
TZ=America/New_York

# Friendly hostname shown in the Dozzle UI
DOZZLE_HOSTNAME=homelab

# Authentication provider: none | simple | forward-proxy
DOZZLE_AUTH_PROVIDER=none

# Traefik: hostname Dozzle will be served on
DOZZLE_DOMAIN=dozzle.yourdomain.com

# Host port for the Dozzle web UI (only used for direct access — Traefik ignores this)
DOZZLE_PORT=8080
