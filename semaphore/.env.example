# Semaphore
# Copy this file to .env and adjust values for your environment.

# Timezone
TZ=America/New_York

# Traefik: hostname Semaphore will be served on
SEMAPHORE_DOMAIN=semaphore.yourdomain.com

# Host port for direct access (Traefik ignores this)
SEMAPHORE_PORT=3003

# Admin credentials (applied on first run only)
SEMAPHORE_ADMIN_PASSWORD=changeme
# SEMAPHORE_ADMIN=admin
# SEMAPHORE_ADMIN_NAME=Admin
# SEMAPHORE_ADMIN_EMAIL=admin@localhost