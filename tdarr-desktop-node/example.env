# Tdarr desktop node — gaming desktop (NVIDIA 3090)
# Copy this file to .env and fill in values

TZ=America/New_York
PUID=1000
PGID=1000

# ── Server connection ──────────────────────────────────────────────────────────
# TrueNAS LAN IP — node connects to the Tdarr server on port 8266
TDARR_SERVER_IP=10.0.0.x
TRUENAS_IP=10.0.0.x

# ── Local data paths (Windows) ─────────────────────────────────────────────────
# Create these directories on the desktop before running
TDARR_CONFIGS_PATH=C:\Docker\tdarr\configs
TDARR_LOGS_PATH=C:\Docker\tdarr\logs
TDARR_TRANSCODE_PATH=C:\Docker\tdarr\transcode-cache
