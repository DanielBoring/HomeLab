TZ=America/New_York

# Domain Traefik routes to n8n
N8N_DOMAIN=n8n.domainname.com

# Host port for direct access (optional)
N8N_PORT=5678

# Encryption key — protects stored credentials in workflows.
# Generate with: openssl rand -hex 32
# NEVER change this after first run — all saved credentials will become unreadable.
N8N_ENCRYPTION_KEY=

# PostgreSQL credentials
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=
