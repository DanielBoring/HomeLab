# Proxmox user for metrics collection.
# Format: <username>@<realm> (e.g. prometheus@pve)
# Create a dedicated read-only user in Proxmox with the PVEAuditor role assigned to path /.
PVE_USER=prometheus@pve

# API token authentication (recommended over password auth).
# Generate in Proxmox: Datacenter > Permissions > API Tokens.
# PVE_TOKEN_NAME is the Token ID (e.g. "monitoring").
# PVE_TOKEN_VALUE is the secret UUID shown once at creation time.
PVE_TOKEN_NAME=your-token-id
PVE_TOKEN_VALUE=your-token-secret

# Set to false only if using self-signed certificates and you cannot import
# the Proxmox CA into your system trust store. Proxmox supports Let's Encrypt
# out of the box, so true is preferred.
PVE_VERIFY_SSL=true
