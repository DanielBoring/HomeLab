# Grafana
# Copy this file to .env and fill in your values.

# Login credentials for the Grafana web UI.
# GRAFANA_ADMIN_USER defaults to "admin" if not set.
# GRAFANA_ADMIN_PASSWORD is required — Grafana will not start without it.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Grafana web UI — default 3000
# GRAFANA_PORT=3000
