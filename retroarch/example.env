TZ=America/New_York
PUID=3001
PGID=3001

RETROARCH_DOMAIN=retroarch.yourdomain.com

# Basic auth credentials for the KasmVNC web interface
RETROARCH_USER=admin
RETROARCH_PASSWORD=changeme

# DRI render node for the Intel Arc GPU.
# Run: ls -la /dev/dri/ to find the correct renderD* device.
INTEL_DRI_NODE=/dev/dri/renderD128

# Path to your ROMs directory on the host
ROMS_PATH=/mnt/Data/Media/ROMs
