# Paperless-ngx
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.

# ─── Secrets ──────────────────────────────────────────────────────────────────

# Django secret key — generate with: openssl rand -hex 32
PAPERLESS_SECRET_KEY=your_secret_key_here

# PostgreSQL password for the paperless database user
PAPERLESS_DBPASS=your_strong_database_password_here

# ─── Admin Account (used on first startup only) ────────────────────────────────
# After the first run these vars are ignored — manage users via the web UI.

PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=your_admin_password_here
PAPERLESS_ADMIN_MAIL=admin@yourdomain.com

# ─── Localization ──────────────────────────────────────────────────────────────

TZ=America/New_York

# Tesseract OCR language(s). Use + to combine: eng+fra
# Full list: https://tesseract-ocr.github.io/tessdoc/Data-Files-in-different-versions.html
PAPERLESS_OCR_LANGUAGE=eng

# ─── Traefik ───────────────────────────────────────────────────────────────────

# Hostname Traefik will route to Paperless
PAPERLESS_DOMAIN=paperless.yourdomain.com

# ─── Ports (optional) ──────────────────────────────────────────────────────────

# Host port for direct access — Traefik uses container port 8000 directly
# PAPERLESS_PORT=8010
