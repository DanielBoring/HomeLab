# Arcane Application Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# Application Settings (non-sensitive, can keep defaults)
APP_URL=http://localhost:3552
PUID=3001
PGID=3001
LOG_LEVEL=info
LOG_JSON=false

# Security Secrets - GENERATE UNIQUE VALUES!
# Use: openssl rand -hex 32
ENCRYPTION_KEY=your_encryption_key_here_64_characters_minimum
JWT_SECRET=your_jwt_secret_here_64_characters_minimum

# Database Configuration
POSTGRES_DB=arcane
POSTGRES_USER=arcane
POSTGRES_PASSWORD=your_strong_database_password_here

# Database Connection String
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# OIDC Configuration
OIDC_ENABLED=false

# HOW TO GENERATE SECURE SECRETS:
#
# For ENCRYPTION_KEY and JWT_SECRET (64 hex characters):
#   openssl rand -hex 32
#
# For POSTGRES_PASSWORD (strong random password):
#   openssl rand -base64 32
#
# IMPORTANT: Each installation should have UNIQUE values!
# Never reuse these across different environments or projects!
