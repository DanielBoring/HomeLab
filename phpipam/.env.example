# phpIPAM
# Copy this file to .env and adjust values for your environment.

# Timezone
TZ=America/New_York

# Traefik: hostname phpIPAM will be served on
PHPIPAM_DOMAIN=ipam.yourdomain.com

# Host port for direct access (Traefik ignores this)
PHPIPAM_PORT=8030

# Database passwords — use long random strings
PHPIPAM_DB_PASSWORD=changeme
PHPIPAM_DB_ROOT_PASSWORD=changeme-root
