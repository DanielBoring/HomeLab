# Linkwarden Configuration
LINKWARDEN_DOMAIN=linkwarden.localhost
TZ=America/New_York

# Database
POSTGRES_USER=linkwarden
# Must be hex — base64 passwords contain +/= which break the DATABASE_URL
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=change_me_secret
POSTGRES_DB=linkwarden

# Linkwarden App
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_secret