# Timezone — IANA tz name (e.g. America/Chicago, Europe/London)
TZ=America/New_York

# Public domain Traefik serves changedetection on
CHANGEDETECTION_DOMAIN=changedetection.example.com

# Host port for direct access (Traefik is primary; this is a fallback)
CHANGEDETECTION_PORT=5000

# Flaresolverr URL — used to bypass Cloudflare-protected sites
# Requires the flaresolverr external network to be reachable
FLARESOLVERR_URL=http://flaresolverr:8191/v1
