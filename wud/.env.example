# What's Up Docker (WUD)
# Copy this file to .env and adjust values for your environment.

# Timezone
TZ=America/New_York

# Traefik: hostname WUD will be served on
WUD_DOMAIN=wud.yourdomain.com

# Host port for direct access (Traefik ignores this)
WUD_PORT=3015

# Discord webhook URL for update notifications
# Create one in your Discord server: Server Settings → Integrations → Webhooks
WUD_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
