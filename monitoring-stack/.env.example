# Monitoring Stack
# Copy this file to .env and fill in your values.

# -------------------------------------------------------------------
# Grafana
# -------------------------------------------------------------------

# Login credentials for the Grafana web UI.
# GRAFANA_ADMIN_USER defaults to "admin" if not set.
# GRAFANA_ADMIN_PASSWORD is required — Grafana will not start without it.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# -------------------------------------------------------------------
# Ports (optional — only set if the defaults conflict with another service)
# -------------------------------------------------------------------

# Grafana web UI — default 3000
# GRAFANA_PORT=3000

# Prometheus web UI and API — default 9090
# PROMETHEUS_PORT=9090

# Loki API — default 3100 (no web UI; queried by Grafana internally)
# LOKI_PORT=3100
